@using OpineHere.mvc.Service;
@model MarkdownPostDto

@{
    ViewBag.Title = Model.Title;
    Layout = "_Layout";
}

<h2>@Model.Title</h2>
<i>@Model.AuthorName</i>
<div class="row">
    <div class="col-sm-10 markdown-container justify-content-end" id="content">
        @Html.Raw(MarkdownService.MarkdownToHtml( Model.RawContent))
    </div>
</div>
@section Scripts{
    
}
