@model OpineHere.mvc.Models.MarkdownPostDto;

@{
    ViewData["Title"] = "Create New Post";
    Layout = "_Layout";
}

<div class="container mt-4">
    <div class="row justify-content-center">
        <div class="col-md-10">
            <h2 class="mb-4">Draft Your Story</h2>
            <hr />

            <form asp-action="AnnonymousPost" method="post">
                <div asp-validation-summary="ModelOnly" class="text-danger"></div>

                @* Title Section *@
                <div class="mb-4">
                    <label asp-for="Title" class="form-label fw-bold"></label>
                    <input asp-for="Title" class="form-control form-control-lg" placeholder="Enter a catchy title..." />
                    <span asp-validation-for="Title" class="text-danger"></span>
                </div>

                @* Author Selection Logic *@
                <div class="card mb-4 bg-light">
                    <div class="card-body">
                        <label class="form-label fw-bold mb-3">Author Identity</label>
                        <div id="penNameSection" class="mt-3">
                            <label asp-for="AuthorName" class="form-label"></label>
                            <input asp-for="AuthorName" class="form-control" placeholder="What should we call you?" />
                            <span asp-validation-for="AuthorName" class="text-danger"></span>
                        </div>
                    </div>
                </div>

                @* Content Section *@
                <div class="mb-4">
                    <div class="d-flex justify-content-between">
                        <label asp-for="RawContent" class="form-label fw-bold">Markdown Content</label>
                        <small class="text-muted">Supports GitHub Flavored Markdown</small>
                    </div>
                    <textarea asp-for="RawContent" class="form-control font-monospace" rows="15" placeholder="Write your thoughts here..."></textarea>
                    <span asp-validation-for="RawContent" class="text-danger"></span>
                </div>

                <div class="d-grid gap-2 d-md-flex justify-content-md-end mb-5">
                    <a asp-action="Index" class="btn btn-outline-secondary px-4">Cancel</a>
                    <button type="submit" class="btn btn-primary px-5">Publish Post</button>
                </div>
            </form>
        </div>
    </div>
</div>